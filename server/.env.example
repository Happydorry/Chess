# PORT is injected automatically by most hosts (Render, Railway, Fly, etc.).
# Leave unset locally to use the default 5001.
# PORT=5001

# Optional game-clock / room tuning (all have sensible defaults in server.js):
# GRACE_MS=30000        # keep a room alive this long after a player drops (ms)
# CLOCK_MS=300000       # initial time per side (ms), default 5 min
# INCREMENT_MS=0        # per-move increment (ms), default none
